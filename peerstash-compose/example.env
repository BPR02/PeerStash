### Set your system timezone. This is used to schedule backups in your local time instead of UTC.
#   https://en.wikipedia.org/wiki/List_of_tz_database_time_zones#List
TZ=America/New_York

### Set the port you want to access the peerstash container from.
#   You should NOT expose this port to the internet.
SSH_PORT=2222

### Set credentials to log in to SSH. Please use a strong password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

### Folders for configuration. These should all be empty when installing for the first time.
#   Backup data will be stored in the SFTP folder, so make sure there is enough space.
PEERSTASH_SFTP=/appdata/peerstash/sftp
PEERSTASH_CONTROL=/appdata/peerstash/control
TAILSCALE_DATA=/appdata/peerstash/tailscale

### Folders for restoration. When restoring or mounting files, they will appear here.
PEERSTASH_RESTORE_FOLDER=/appdata/peerstash/restored_files
PEERSTASH_MOUNTS=/appdata/peerstash/mounts

### Set the root folder that peerstash will read from to create backups. 
#   Peerstash cannot access files outside of this directory.
PEERSTASH_ROOT_TARGET=/home

### Set the default quota for each peer 
DEFAULT_QUOTA_GB=100
